alias hssh="ssh sami@httpster.io"
alias vssh="vagrant ssh"
alias vup="vagrant up"
alias valt="vagrant halt"
alias vpend="vagrant suspend"
alias cmderr="cd /d %CMDER_ROOT%"
alias e.="explorer ."
alias ls="ls --show-control-chars -F --color $*"
alias pwd="cd"
alias unalias="alias /d $1"
alias gl="git log --oneline --all --graph --decorate $*"
alias proj="cd G:/Projects"
alias st="snippingtool"